# ==========================================
# Pharmony Workspace Root GitIgnore
# Configured for:
# - Django Backend (inside /Pharmony)
# - Angular Frontend (inside /PharmonyFront)
# ==========================================

# ------------------------------------------
# Django Backend (Pharmony/)
# ------------------------------------------
# Byte-compiled / optimized / DLL files
Pharmony/**/*.py[cod]
Pharmony/**/__pycache__/
Pharmony/**/*.so

# Local environments / secrets
Pharmony/.env
Pharmony/ServiceAccountKey.json

# Database
Pharmony/db.sqlite3
Pharmony/db.sqlite3-journal

# Environments
Pharmony/venv/
Pharmony/.venv/
Pharmony/env/
Pharmony/ENV/
Pharmony/env.bak/
Pharmony/venv.bak/

# Django media & static files
Pharmony/media/
Pharmony/staticfiles/

# Logs
Pharmony/*.log

# Pytest / Coverage
Pharmony/.pytest_cache/
Pharmony/htmlcov/
Pharmony/.coverage
Pharmony/.coverage.*


# ------------------------------------------
# Angular Frontend (PharmonyFront/)
# ------------------------------------------
# Node modules
PharmonyFront/node_modules/

# Angular build outputs and cache
PharmonyFront/dist/
PharmonyFront/tmp/
PharmonyFront/out-tsc/
PharmonyFront/bazel-out/
PharmonyFront/.angular/

# Logs
PharmonyFront/npm-debug.log
PharmonyFront/yarn-error.log
PharmonyFront/testem.log
PharmonyFront/libpeerconnection.log

# Miscellaneous Angular items
PharmonyFront/coverage/
PharmonyFront/.sass-cache/
PharmonyFront/connect.lock
PharmonyFront/typings/
PharmonyFront/__screenshots__/


# ------------------------------------------
# Global / IDE / System Settings
# ------------------------------------------
# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/

# System files
.DS_Store
Thumbs.db